# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── JWT (generate with: openssl rand -hex 32) ───────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
FELOVY_SIGNUP_RESEND_API_KEY=
RESEND_FROM=Felovy <noreply@felovy.com>

# ─── ImageKit ────────────────────────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# ─── Bot portrait APIs (optional — live search; curated pools used when unset) ─
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Owner & Admin ───────────────────────────────────────────────────────────
OWNER_EMAIL=
OWNER_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Felovy
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — Google Search Console HTML tag verification
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Feli AI Guide (OpenRouter-compatible API) ───────────────────────────────
OPENAI_API_KEY=
AI_MODEL=anthropic/claude-haiku-4.5
