generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  DEVELOPER
  EMPLOYER
  OWNER
}

enum UserStatus {
  ACTIVE
  MUTED
  BANNED
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

enum LocationType {
  ONSITE
  HYBRID
  REMOTE
}

enum SalaryType {
  HOURLY
  MONTHLY
  YEARLY
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  ACCEPTED
}

// ─── Core User ──────────────────────────────────────────────────────────────

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String?
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  developer    Developer?
  employer     Employer?
  otpCodes     OtpCode[]
  favoriteJobs FavoriteJob[]

  @@map("users")
}

// ─── Developer ──────────────────────────────────────────────────────────────

model Developer {
  id       String @id @default(uuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Step 2
  fullName       String?
  title          String?
  phone          String?
  location       String?
  country        String?
  gender         String?
  birthYear      Int?
  linkedin       String?
  github         String?
  summary        String?
  skills         String[]
  workExperience Json?
  education      Json?
  languages      Json      @default("[]")

  // Step 3
  photoUrl       String?
  introVideoUrl  String?
  introVideoType String?

  // Step 4
  idCardUrl String?

  profileStep Int     @default(1)
  isVerified  Boolean @default(false)
  verifiedAt  DateTime?
  isBot       Boolean @default(false)

  applications        Application[]
  messages            Message[]
  directConversations Conversation[] @relation("DirectConvos")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("developers")
}

// ─── Employer ───────────────────────────────────────────────────────────────

model Employer {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Step 2
  companyName      String?
  companyWebsite   String?
  companySummary   String?
  companySize      String?
  companyLocation  String?
  country          String?
  companyLinkedin  String?
  contactName      String?
  contactRole      String?
  contactInfo      String?

  // Step 3
  companyLogoUrl  String?
  companyBrandUrl String?
  companyAdImages String[]
  contactPhotoUrl String?
  introVideoUrl   String?
  introVideoType  String?

  // Step 4
  idCardUrl String?

  profileStep Int     @default(1)
  isVerified  Boolean @default(false)
  verifiedAt  DateTime?

  jobs          Job[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employers")
}

// ─── OTP Codes ──────────────────────────────────────────────────────────────

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  type      String   // signup | email_change
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

// ─── Jobs ───────────────────────────────────────────────────────────────────

model Job {
  id         String   @id @default(uuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  title           String
  logoUrl         String?
  companyLocation String?
  locationType    LocationType

  salaryMin  Float?
  salaryMax  Float?
  salaryType SalaryType?
  currency   String?

  requiredSkills   String[]
  niceToHaveSkills String[]
  languages        String[]
  industry         String?
  description      String?

  status    JobStatus @default(PENDING)
  isPinned  Boolean   @default(false)
  isEnabled Boolean   @default(true)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications Application[]
  favorites    FavoriteJob[]

  @@map("jobs")
}

// ─── Applications ───────────────────────────────────────────────────────────

model Application {
  id          String @id @default(uuid())
  jobId       String
  job         Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  coverLetter String?
  appliedData Json

  status ApplicationStatus @default(PENDING)

  conversation Conversation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, developerId])
  @@map("applications")
}

// ─── Conversations & Messages ────────────────────────────────────────────────

model Conversation {
  id            String       @id @default(uuid())
  applicationId String?      @unique
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Direct DM participants (populated when applicationId is null)
  developerId     String?
  developer       Developer? @relation("DirectConvos", fields: [developerId], references: [id])
  employerId      String?
  employer        Employer?  @relation(fields: [employerId], references: [id])
  initiatorUserId String?    // userId of OWNER when OWNER initiates the DM

  isBlocked Boolean @default(false)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderRole     Role

  content     String
  attachments String[]

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Developer sender link (optional — senderRole determines which)
  developer   Developer? @relation(fields: [senderId], references: [id])

  @@map("messages")
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model FavoriteJob {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@map("favorite_jobs")
}
